{
  "schemaVersion": "optimusctx/benchmark-suite@v2",
  "id": "go-benchmark-refresh-v1",
  "version": "v1",
  "name": "Go benchmark refresh recovery and bounded context",
  "description": "Paired refresh-after-change and bounded-context benchmark on the frozen go-worktree fixture using declared counted readiness inputs plus comparable final artifacts.",
  "boundary": {
    "countedInputs": "declared_agent_inputs_only",
    "systemOutputs": "persist_system_outputs",
    "finalArtifacts": "required_per_lane_or_task"
  },
  "fixture": {
    "id": "go-worktree",
    "version": "v1",
    "path": "go-worktree/v1/repository",
    "materialize": "copy_tree",
    "workspaceDir": "workspace"
  },
  "task": {
    "id": "docs-context",
    "prompt": "Refresh after a controlled docs change, then fetch the bounded updated notes context needed to explain the change.",
    "targetPath": "docs/notes.txt",
    "contextPaths": [
      "docs/notes.txt"
    ]
  },
  "countedInputs": [
    {
      "id": "baseline-tracked-file-hints",
      "armKind": "baseline",
      "lane": "refresh_after_change",
      "stepId": "baseline-git-files",
      "name": "Baseline tracked-file hints",
      "kind": "path_list",
      "sourceKind": "path_estimate",
      "path": "docs"
    },
    {
      "id": "baseline-mutated-note-match",
      "armKind": "baseline",
      "lane": "refresh_after_change",
      "stepId": "baseline-grep-notes",
      "name": "Baseline mutated note matches",
      "kind": "path_list",
      "sourceKind": "path_estimate",
      "path": "docs/notes.txt"
    },
    {
      "id": "treatment-health-freshness",
      "armKind": "optimusctx",
      "lane": "refresh_after_change",
      "stepId": "opti-health",
      "name": "Projected health freshness",
      "kind": "json_field_projection",
      "sourceKind": "direct_payload",
      "artifactType": "health",
      "reportLabel": "operational",
      "jsonPath": "Refresh.Freshness"
    },
    {
      "id": "treatment-health-generation",
      "armKind": "optimusctx",
      "lane": "refresh_after_change",
      "stepId": "opti-health",
      "name": "Projected health generation",
      "kind": "json_field_projection",
      "sourceKind": "direct_payload",
      "artifactType": "health",
      "reportLabel": "operational",
      "jsonPath": "Refresh.CurrentGeneration"
    },
    {
      "id": "baseline-updated-notes-slice",
      "armKind": "baseline",
      "lane": "task_completion",
      "stepId": "baseline-read-docs",
      "name": "Baseline updated notes slice",
      "kind": "file_slice",
      "sourceKind": "bounded_file_content",
      "path": "docs/notes.txt",
      "startLine": 1,
      "endLine": 40
    },
    {
      "id": "treatment-updated-notes-context",
      "armKind": "optimusctx",
      "lane": "task_completion",
      "stepId": "opti-targeted-context",
      "name": "Treatment bounded updated notes context",
      "kind": "text_output",
      "sourceKind": "direct_payload",
      "artifactType": "l2_context",
      "reportLabel": "l2_context",
      "path": "artifacts/updated-notes.txt"
    }
  ],
  "lanes": [
    {
      "name": "refresh_after_change",
      "description": "Return the repository to usable state after a deterministic mutation.",
      "startMarker": "refresh_after_change_started",
      "successMarker": "refresh_ready",
      "setup": [
        {
          "kind": "overwrite_file",
          "path": "docs/notes.txt",
          "content": "bounded context should include this deterministic fixture content after benchmark mutation\n"
        }
      ],
      "assert": [
        {
          "file": "docs/notes.txt",
          "kind": "contains",
          "contains": "after benchmark mutation"
        }
      ],
      "finalArtifact": {
        "id": "refresh-readiness",
        "name": "Normalized refresh readiness summary",
        "kind": "readiness_summary",
        "path": "artifacts/readiness.json",
        "format": "json",
        "normalization": {
          "mode": "json_fields",
          "jsonPaths": [
            "targetReady"
          ]
        },
        "assert": [
          {
            "kind": "json_field_equals",
            "path": "targetReady",
            "equals": true
          }
        ]
      },
      "stopCondition": {
        "kind": "marker",
        "marker": "refresh_ready"
      },
      "metrics": [
        "targeted_lookup_actions",
        "consulted_artifacts"
      ]
    },
    {
      "name": "task_completion",
      "description": "Produce the final task artifact once the repository is ready again.",
      "startMarker": "task_completion_started",
      "successMarker": "task_complete",
      "assert": [
        {
          "file": "docs/notes.txt",
          "kind": "contains",
          "contains": "after benchmark mutation"
        }
      ],
      "finalArtifact": {
        "id": "updated-notes-context",
        "name": "Normalized updated notes context",
        "kind": "task_output",
        "path": "artifacts/updated-notes.txt",
        "format": "text",
        "normalization": {
          "mode": "text_trimmed",
          "trimWhitespace": true
        },
        "assert": [
          {
            "kind": "contains",
            "contains": "after benchmark mutation"
          }
        ]
      },
      "stopCondition": {
        "kind": "marker",
        "marker": "task_complete"
      },
      "metrics": [
        "file_read_actions",
        "bytes_read"
      ]
    }
  ],
  "arms": [
    {
      "kind": "baseline",
      "name": "Baseline exact-search workflow",
      "description": "Replayable baseline workflow using git listing, exact search, bounded reads, and explicit completion markers.",
      "steps": [
        {
          "id": "baseline-git-files",
          "name": "Inspect tracked files",
          "lane": "refresh_after_change",
          "baseline": {
            "kind": "git_list_files"
          }
        },
        {
          "id": "baseline-grep-notes",
          "name": "Search docs note",
          "lane": "refresh_after_change",
          "baseline": {
            "kind": "git_grep",
            "query": "after benchmark mutation"
          }
        },
        {
          "id": "baseline-refresh-done",
          "name": "Mark refresh-ready state",
          "lane": "refresh_after_change",
          "baseline": {
            "kind": "mark_lane_complete",
            "marker": "refresh_ready"
          }
        },
        {
          "id": "baseline-read-docs",
          "name": "Read docs slice",
          "lane": "task_completion",
          "baseline": {
            "kind": "read_file_slice",
            "path": "docs/notes.txt",
            "startLine": 1,
            "endLine": 40
          }
        },
        {
          "id": "baseline-task-done",
          "name": "Mark task completion",
          "lane": "task_completion",
          "baseline": {
            "kind": "mark_lane_complete",
            "marker": "task_complete"
          }
        }
      ]
    },
    {
      "kind": "optimusctx",
      "name": "OptimusCtx CLI and MCP workflow",
      "description": "Refresh and health stay as provenance and timing evidence unless the suite explicitly projects readiness fields into counted agent input.",
      "steps": [
        {
          "id": "opti-refresh",
          "name": "Run shipped refresh command",
          "lane": "refresh_after_change",
          "treatment": {
            "surface": "cli",
            "command": "refresh"
          }
        },
        {
          "id": "opti-health",
          "name": "Check repository health",
          "lane": "refresh_after_change",
          "treatment": {
            "surface": "mcp",
            "tool": "optimusctx.health"
          }
        },
        {
          "id": "opti-targeted-context",
          "name": "Fetch bounded updated notes context",
          "lane": "task_completion",
          "treatment": {
            "surface": "mcp",
            "tool": "optimusctx.targeted_context"
          }
        }
      ]
    }
  ]
}
